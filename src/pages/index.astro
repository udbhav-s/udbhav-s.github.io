---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout title="Udbhav Saxena">
  <main>
    <div class="name-heading-container">
      <h1>Udbhav Saxena</h1>
    </div>

    <div class="container">
      <div>
        <img src="/assets/images/home/me.jpg" alt="A picture of me (Udbhav)" />
      </div>

      <div class="text">
        <p>
          CS + Math undergrad @ Michigan State University. I like exploring
          cybersecurity, applied cryptography, web development, UX, and data visualization! <br>
          I am currently doing research in zero-knowledge proofs and their performance engineering. 
        </p>
        <a href="/resume" class="resume-link">
          <h4>
          View my resume →
          </h4>
        </a>
        <p>
          <div>Links:</div>
          <a
            href="https://drive.google.com/file/d/1g9IY8k6x_YJfs7FOABKgc2d6Rix9ANuy/view?usp=sharing"
            >Resume (PDF)</a
          > |
          <a href="https://github.com/udbhav-s">GitHub</a> |
          <a href="https://www.linkedin.com/in/udbhav-saxena-748160217/"
            >LinkedIn</a
          >
        </p>
      </div>
    </div>

    <!-- <h2>Blog</h2>
    <div>Post coming soon!</div> -->
    <h2>Pinned 📌</h2>
    <div class="card-list">
      <div>
        <Card
          href="https://thearchivehps.netlify.app/"
          title="The Archive @ HPSB"
          body="Interactive installation at the centenary museum of The Hyderabad Public School, Begumpet"
        />
      </div>
      <div>
        <Card
          href="https://spartancybersecurityclub.github.io/pages/ectf-2025.html"
          title="MITRE eCTF 2025"
          body="Designing a secure Satellite TV PKI with Rust for the 2025 embedded security competition."
        />
      </div>
      <div>
        <Card
          href="https://spartancybersecurityclub.github.io/pages/ectf-2024.html"
          title="MITRE eCTF 2024"
          body="An overview of the 2024 semester-long cybersecurity competition, where we implemented a secure medical device."
        />
      </div>
    </div>

    <h2>Hackathon projects</h2>
    <p>Stuff I've made at hackathons</p>
    <div class="card-list">
      <div>
        <Card
          href="https://github.com/udbhav-s/un-mirror-worlds"
          title="Mirror Worlds"
          body="(UN Open Source Week 2026) Tool that collects evidence-based case studies using data from the United Nations and more datasets, and compares them with input reports to rate data provenance and quality."
        />
      </div>
      <div>
        <Card
          href="https://github.com/dheerajt10/diagonalize"
          title="Diagonalize"
          body="(HackMIT 2025) Private OAuth provider that runs email verification inside a Trusted Execution Environment."
        />
      </div>
      <div>
        <Card
          href="https://devpost.com/software/fluxus-a4bgv1"
          title="Fluxus"
          body="(HackMIT 2023) Tool to iteratively work with healthcare data frames using natural language queries."
        />
      </div>
      <div>
        <Card
          href="https://devpost.com/software/proximitycast"
          title="ProximityCast"
          body="Using cryptography for private proximity detection and broadcasting local events."
        />
      </div>
    </div>

    <h2>Random</h2>
    <div class="card-list">
      <div>
        <Card
          href="https://github.com/udbhav-s/ableton-track-deleter"
          title="Track Deleter Utility for Ableton Live"
          body="Small utility to delete tracks from corrupt project files that cause Ableton to crash"
        />
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 1rem;
    width: 800px;
    max-width: calc(100% - 2rem);
    color: var(--color-text);
    font-size: 20px;
    line-height: 1.6;

    border-left: var(--border-main);
  }

  a {
    color: var(--color-link);
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
  }

  h1::after {
    width: 200vw;
    position: absolute;
    transform: translateX(-100vw);
    content: "";
    margin-top: 1rem;
    display: block;
    border-bottom: var(--border-main);
  }

  .name-heading-container {
    margin-bottom: 2rem;
    max-width: 100%;
  }

  .resume-link {
    display: inline-block;
    text-decoration: none;
    border: var(--border-main);
    border-style: dashed;
    padding: 1rem;
  }

  .resume-link:hover {
    background: var(--color-text);

    & h4 {
      color: var(--color-bg);
    }
  }

  .resume-link h4 {
    margin: 0;
  }

  .container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    column-gap: 3rem;
  }

  .container img {
    border-radius: 0px;
    border: var(--border-main);
  }

  h2 {
    margin-bottom: 0px;
  }

  .card-list > * {
    margin-top: 1rem;
  }
</style>
