              <span class="date">{ed.date}</span>
            </div>
            <div class="resume-entry-subtitle">
              <strong>{ed.degree}</strong> | {ed.location}
            </div>
            <div class="resume-entry-details">
              <em>{ed.details}</em>
            </div>
            <div class="resume-entry-coursework">
              <strong>Relevant Coursework:</strong> {ed.coursework}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2>Experience</h2>
      <div class="resume-list">
        {experience.map(exp => (
          <div class="resume-entry">
            <div class="resume-entry-header">
              <h3>{exp.title}</h3>
              <span class="date">{exp.date}</span>
            </div>
            <div class="resume-entry-subtitle">
              <strong>{exp.company}</strong> | {exp.location}
            </div>
            {exp.advisor && <div class="resume-entry-advisor"><em>Advisor: {exp.advisor}</em></div>}
