</Layout>

<style>
  main {
    margin: auto;
    padding: 1rem;
    width: 800px;
    max-width: calc(100% - 2rem);
    color: var(--color-text);
    font-size: 18px;
    line-height: 1.6;
    border-left: var(--border-main);
  }

  a {
    color: var(--color-link);
  }
  
  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-weight: 600;
    text-decoration: none;
    font-size: 1.1rem;
  }
  
  .back-link:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  h1::after {
    width: 200vw;
    position: absolute;
    transform: translateX(-100vw);
    content: "";
    margin-top: 1rem;
    display: block;
    border-bottom: var(--border-main);
  }

  h2 {
    font-size: 1.8rem;
    margin-top: 2.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px dashed var(--color-text);
    padding-bottom: 0.5rem;
  }

  h3 {
    font-size: 1.25rem;
    margin: 0;
  }

  .name-heading-container {
    margin-bottom: 2rem;
    max-width: 100%;
  }

  .summary {
    font-size: 1.1rem;
  }
  
  .contact-links {
    font-weight: bold;
    margin-top: 0.5rem;
  }

  .resume-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .resume-entry {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .resume-entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .date {
    font-weight: 600;
    font-family: Menlo, Monaco, Lucida Console, Liberation Mono, DejaVu Sans Mono, Bitstream Vera Sans Mono, Courier New, monospace;
    font-size: 0.9rem;
    color: var(--color-accent);
  }

  .resume-entry-subtitle, .resume-entry-details, .resume-entry-advisor, .resume-entry-coursework {
    font-size: 1rem;
  }

  .resume-bullets {
    margin: 0.5rem 0 0 0;
    padding-left: 1.5rem;
    font-size: 1rem;
  }
  
  .resume-bullets li {
    margin-bottom: 0.3rem;
  }

  .skills-list {
    padding-left: 1.5rem;
    font-size: 1rem;
  }
  
  .skills-list li {
    margin-bottom: 0.5rem;
  }

  /* Projects Filter Tags */
  .projects-filter {
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .projects-filter span {
    font-weight: bold;
    display: block;
    margin-bottom: 0.5rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-btn {
    background: transparent;
    border: var(--border-main);
    color: var(--color-text);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.9rem;
    cursor: pointer;
    font-family: var(--font-heading);
    transition: all 0.2s ease;
  }

  .tag-btn:hover {
    background: var(--color-card-hover-bg);
  }

  .tag-btn.active {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .tag {
    background: var(--color-text);
    color: var(--color-bg);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.tag-btn');
    const projectEntries = document.querySelectorAll('.project-entry');
    let activeTag = null;

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-tag');
        
        if (activeTag === tag) {
          // Deselect
          activeTag = null;
          btn.classList.remove('active');
        } else {
          // Select new tag
          filterBtns.forEach(b => b.classList.remove('active'));
          activeTag = tag;
          btn.classList.add('active');
        }

        // Filter projects
        projectEntries.forEach(entry => {
          if (!activeTag) {
            entry.style.display = 'flex';
          } else {
            const tags = (entry.getAttribute('data-tags') || '').split(',');
            if (tags.includes(activeTag)) {
              entry.style.display = 'flex';
            } else {
              entry.style.display = 'none';
            }
          }
        });
      });
    });
  });
</script>
